# Copy to .env and adjust as needed. Every variable is optional; the values
# below are the defaults that apply when a variable is unset.

# Bind address/port when running outside Docker. The Docker image overrides
# HOST to 0.0.0.0 internally; host exposure is controlled by the compose port
# mapping instead (see docker-compose.yml).
HOST=127.0.0.1
PORT=8000

# How many downloads run at the same time; additional requests wait in a queue.
MAX_CONCURRENT_DOWNLOADS=1

# Maximum running + queued downloads before new requests are rejected (HTTP 429).
MAX_PENDING_DOWNLOADS=10

# Refuse to download files larger than this many megabytes.
MAX_FILESIZE_MB=5120

# Downloaded files and task state older than this many minutes are deleted.
FILE_TTL_MINUTES=60

# Optional, comma-separated. When set, requests whose Host header doesn't match
# are rejected (protects against DNS rebinding), e.g.: localhost,127.0.0.1
#ALLOWED_HOSTS=
